---
import { getCollection } from 'astro:content';
import BlogCard from '@components/ui/BlogCard.astro';

export interface Props {
  locale: 'en' | 'vi';
}

const { locale } = Astro.props;

const posts = await getCollection('blog', ({ data }) => {
  return !data.draft && data.locale === locale;
});

posts.sort((a, b) => {
  return new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();
});
---

<div class="blog-list">
  {posts.length === 0 && (
    <p class="empty-state">{locale === 'vi' ? 'Chưa có bài viết nào.' : 'No posts yet.'}</p>
  )}
  {posts.map((post) => (
    <BlogCard post={post} />
  ))}
</div>

<style>
  .blog-list {
    display: flex;
    flex-direction: column;
  }

  .empty-state {
    color: var(--muted);
    font-size: 14px;
    padding: 24px 0;
  }
</style>
