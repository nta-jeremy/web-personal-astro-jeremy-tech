---
import Layout from '@layouts/BaseLayout.astro';
import { getTranslations, t } from '@/i18n/utils';
import ContactInfo from '@components/sections/ContactInfo.astro';

const locale = Astro.currentLocale || 'vi';
const translations = getTranslations(locale as 'en' | 'vi');

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jeremy Nguyen',
  jobTitle: 'CTO · AI Builder',
  url: 'https://jeremytech.io.vn',
  email: 'jeremy@example.com',
  sameAs: [
    'https://github.com/jeremynguyen',
    'https://linkedin.com/in/jeremynguyen',
    'https://x.com/jeremynguyen',
  ],
};
---

<Layout title={t(translations, 'contact.title')} description={t(translations, 'contact.subtitle')}>
  <div class="artifact contact-page">
    <ContactInfo translations={translations} />
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
</Layout>

<style>
  .contact-page {
    padding-top: 8px;
  }
</style>
