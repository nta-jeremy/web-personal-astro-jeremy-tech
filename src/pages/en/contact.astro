---
import Layout from '@layouts/BaseLayout.astro';
import { getTranslations, t } from '@/i18n/utils';
import ContactPage from '@components/sections/ContactPage.astro';

const locale = Astro.currentLocale || 'en';
const translations = getTranslations(locale as 'en' | 'vi');
---

<Layout title={t(translations, 'contact.title')} description={t(translations, 'contact.subtitle')}>
  <div class="artifact contact-page">
    <ContactPage translations={translations} locale={locale as 'en' | 'vi'} />
  </div>
</Layout>

<style>
  .contact-page {
    padding-top: 8px;
    position: relative;
  }
  @media (max-width: 1100px) {
    :global(.contact-sidebar) {
      display: none !important;
    }
  }
</style>
