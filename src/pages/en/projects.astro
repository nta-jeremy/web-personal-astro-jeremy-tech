---
import Layout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getTranslations, t } from '@/i18n/utils';

const locale = Astro.currentLocale || 'en';
const translations = getTranslations(locale as 'en' | 'vi');

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();
});

const allCategories = Array.from(
  new Set(projects.flatMap((p) => p.data.categories || []))
).sort();
const filterOptions = [
  { value: 'all', label: t(translations, 'projects.filterAll') },
  ...allCategories.map((c) => ({ value: c, label: c })),
];
---

<Layout
  title={t(translations, 'meta.projectsTitle')}
  description={t(translations, 'meta.projectsDescription')}
  ogTitle={t(translations, 'meta.ogProjectsTitle')}
  image="/og-default.png"
>
  <div class="artifact">
    <div
      style="font-size: 10.5px; color: var(--subtle); letter-spacing: 0.18em; font-weight: 600; margin-bottom: 12px; text-transform: uppercase;"
    >
      {t(translations, 'projects.label')}
    </div>

    <h1
      class="serif"
      style="font-size: 56px; font-weight: 500; line-height: 1.02; letter-spacing: -0.02em; margin: 0 0 14px;"
    >
      {t(translations, 'projects.heading')}
    </h1>

    <p
      style="font-size: 16px; color: var(--muted); line-height: 1.65; margin: 0 0 32px; max-width: 540px;"
    >
      {t(translations, 'projects.subtitle')}
    </p>

    <div class="project-filters" data-filters>
      {
        filterOptions.map((opt, i) => (
          <button
            class={`project-filter-chip${i === 0 ? ' active' : ''}`}
            data-filter={opt.value}
            type="button"
          >
            {opt.label}
          </button>
        ))
      }
    </div>

    <div class="project-list">
      {
        projects.map((project, index) => (
          <div
            class={`project-list-item${project.data.featured ? ' featured' : ''}`}
            data-index={index}
            data-categories={JSON.stringify(project.data.categories || [])}
          >
            {project.data.featured && (
              <div class="project-list-image">
                <div class="project-image-placeholder">
                  <svg width="100%" height="100%" class="project-image-svg">
                    <defs>
                      <pattern
                        id={`pp-${index}`}
                        width="22"
                        height="22"
                        patternUnits="userSpaceOnUse"
                      >
                        <circle cx="11" cy="11" r="0.6" fill="#f4d4b5" />
                      </pattern>
                    </defs>
                    <rect width="100%" height="100%" fill={`url(#pp-${index})`} />
                    <g
                      stroke="#f4d4b5"
                      stroke-width="0.4"
                      fill="none"
                      opacity="0.5"
                    >
                      <path d="M20 20 L200 120 M20 120 L200 20 M100 20 L100 120 M20 70 L200 70" />
                    </g>
                  </svg>
                </div>
              </div>
            )}
            <div class="project-list-content">
              {project.data.categories && project.data.categories.length > 0 && (
                <div style="display: flex; gap: 6px; margin-bottom: 10px; flex-wrap: wrap;">
                  {project.data.categories.map((cat) => (
                    <span class="tag">{cat}</span>
                  ))}
                </div>
              )}
              <a href={`/projects/${project.id}/`} style="text-decoration: none; color: inherit;">
                <h2
                  class="serif"
                  style="font-size: 28px; font-weight: 500; line-height: 1.2; letter-spacing: -0.01em; margin: 0 0 10px;"
                >
                  {project.data.title}
                </h2>
              </a>
              <p
                style="font-size: 14.5px; color: var(--muted); line-height: 1.65; margin: 0 0 12px;"
              >
                {project.data.description}
              </p>
              {project.data.featured && (
                <a
                  href={`/projects/${project.id}/`}
                  style="font-size: 12px; color: var(--accent); font-weight: 600; letter-spacing: 0.1em; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; text-transform: uppercase; min-height: 44px;"
                >
                  {t(translations, 'projects.explore')}
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    width="14"
                    height="14"
                  >
                    <path d="M5 12h14M13 5l7 7-7 7" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Layout>

<script>
  (function () {
    const container = document.querySelector('[data-filters]');
    if (!container) return;
    const chips = container.querySelectorAll('[data-filter]');
    const items = document.querySelectorAll('.project-list-item');

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const filter = chip.getAttribute('data-filter') || 'all';

        chips.forEach((c) => c.classList.remove('active'));
        chip.classList.add('active');

        items.forEach((item) => {
          const catsRaw = item.getAttribute('data-categories');
          const cats: string[] = catsRaw ? JSON.parse(catsRaw) : [];
          if (filter === 'all' || cats.includes(filter)) {
            (item as HTMLElement).style.display = '';
          } else {
            (item as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  })();
</script>

<style>
  .project-filters {
    display: flex;
    gap: 8px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }
  .project-filter-chip {
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 12px;
    letter-spacing: 0.04em;
    border: 1px solid var(--border-2);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
    min-height: 44px;
  }
  .project-filter-chip:hover {
    border-color: var(--ink);
    color: var(--ink);
  }
  .project-filter-chip.active {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }
  .project-list {
    display: flex;
    flex-direction: column;
  }
  .project-list-item {
    padding: 28px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  .project-list-item:first-child {
    border-top: 1px solid var(--border);
  }
  .project-list-item.featured {
    grid-template-columns: 220px 1fr;
    gap: 28px;
  }
  .project-list-image {
    width: 220px;
    height: 140px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .project-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #3a2620, #6b3a28 60%, #c27a5c);
    position: relative;
  }
  .project-image-svg {
    position: absolute;
    inset: 0;
  }
  @media (max-width: 767px) {
    .project-list-item.featured {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .project-list-image {
      width: 100%;
      height: 160px;
    }
  }
</style>